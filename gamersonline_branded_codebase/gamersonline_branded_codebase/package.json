{
  "name": "gamersonline-branded-codebase",
  "private": true,
  "version": "1.3.0",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev:web": "npm --workspace apps/web run dev",
    "dev:api": "npm --workspace apps/api run start:dev",
    "dev:worker": "npm --workspace apps/worker run dev",
    "build:web": "npm --workspace apps/web run build",
    "build:api": "npm --workspace apps/api run build",
    "build:worker": "npm --workspace apps/worker run build",
    "db:generate": "npm --workspace packages/database run generate",
    "db:migrate": "npm --workspace packages/database run migrate"
  }
}
